# Gemini AI (expense categorization + advisor chat)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase — required for email/password auth
# Option A: paste from Firebase Console → Project settings → Your apps → Web app
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Option B: values can be read from google-services.json:
#   apiKey          → client[0].api_key[0].current_key
#   authDomain      → {project_id}.firebaseapp.com
#   projectId       → project_info.project_id
#   storageBucket   → project_info.storage_bucket
#   messagingSenderId → project_info.project_number
#   appId           → client[0].client_info.mobilesdk_app_id
#
# client_secret.json is NOT needed for email/password auth — do not commit it.
